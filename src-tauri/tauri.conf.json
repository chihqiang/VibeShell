{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeShell",
  "version": "0.0.1",
  "identifier": "com.chihqiang.vibeshell",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VibeShell",
        "decorations": false,
        "minWidth": 1000,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2QzMyQThDNzVERTEzQkQKUldTOUU5NTFqQ3JETmpZcktPRERVdXNaSmdua3A0VjZmQnVrQnp5a3pCSkdYMlp1c0k0ekIrTzgK",
      "endpoints": [
        "https://github.com/chihqiang/VibeShell/releases/latest/download/updater.json"
      ]
    }
  }
}
